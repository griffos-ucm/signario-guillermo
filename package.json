{
  "name": "guillermo",
  "version": "26.3.22",
  "description": "Guillermo: aplicación de gestión de la BD del Signario",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "targets": {
    "table": {
      "source": "src/table/index.html",
      "publicUrl": "./",
      "distDir": "dist/table"
    },
    "detail": {
      "source": "src/detail/index.html",
      "publicUrl": "./",
      "distDir": "dist/detail"
    },
    "import": {
      "source": "src/import/index.html",
      "publicUrl": "./",
      "distDir": "dist/import"
    }
  },
  "author": "Antonio F. G. Sevilla <afgs@ucm.es>",
  "license": "OSL-3.0",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "marked": "^17.0.5",
    "node-fetch-cjs": "^3.2.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "electron": "41.0.3",
    "electron-builder": "^26.8.1",
    "parcel": "^2.6.2",
    "signotator": "file:../signotator",
    "tailwindcss": "^4.2.2"
  },
  "build": {
    "appId": "com.garciasevilla.guillermo",
    "files": [
      "dist/*/*.html",
      "dist/*/*.js",
      "dist/*/*.css",
      "src/*.js",
      "src/*/back.js",
      "src/partial_import.js"
    ],
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "volta": {
    "node": "22.12.0"
  }
}
